<?xml version="1.0"?>
<Container version="2">
  <Name>Checkmk-Server</Name>
  <Repository>checkmk/check-mk-raw:2.4.0-latest</Repository>
  <Registry>https://hub.docker.com/r/checkmk/check-mk-raw</Registry>

  <!-- NETWORK: Leave as 'bridge' (default) or set to a custom macvlan/bridge network.
       Recommended: Use a macvlan network (e.g. br0) or a dedicated Docker bridge
       network to give Checkmk its own IP. This avoids port conflicts and allows
       Checkmk agents to reach the server directly. Default 'bridge' works but is
       less ideal for production monitoring. -->
  <Network>bridge</Network>
  <MyIP/>

  <Shell>bash</Shell>
  <Privileged>false</Privileged>

  <Overview>Checkmk Raw Edition 2.4 – Open-Source IT Monitoring for Unraid. NOTE: In Checkmk 2.4 Docker, the site name is always 'cmk' (hardcoded). WebUI: http://[IP]:8080/cmk/</Overview>
  <Category>Network:Management Tools:Utilities</Category>

  <WebUI>http://[IP]:[PORT:8080]/cmk/</WebUI>

  <Icon>https://dashboardicons.com/icons/checkmk.png</Icon>

  <!-- tmpfs only for the Checkmk tmp directory – required for correct startup -->
  <ExtraParams>--tmpfs /opt/omd/sites/cmk/tmp:uid=1000,gid=1000 --ulimit nofile=1024:1024</ExtraParams>

  <PostArgs/>
  <CPUset/>
  <Support>https://buymeacoffee.com/hannesdi</Support>
  <DonateText/>
  <DonateLink/>
  <Requires/>

  <!-- ════════════════════════════════════════
       PORTS
       ════════════════════════════════════════ -->
  <Config
    Name="WebUI Port (HTTP)"
    Target="5000"
    Default="8080"
    Mode="tcp"
    Description="Checkmk Web UI port. Access via http://[IP]:8080/cmk/ after start."
    Type="Port"
    Display="always"
    Required="true"
    Mask="false">8080</Config>

  <Config
    Name="Agent Receiver Port"
    Target="8000"
    Default="8000"
    Mode="tcp"
    Description="Port for Checkmk push-mode agents. Required if you use agent push instead of pull."
    Type="Port"
    Display="advanced"
    Required="false"
    Mask="false">8000</Config>

  <!-- ════════════════════════════════════════
       ENVIRONMENT VARIABLES
       ════════════════════════════════════════ -->
  <Config
    Name="Admin Password"
    Target="CMK_PASSWORD"
    Default=""
    Mode=""
    Description="Password for the 'cmkadmin' web UI user. Only applied on first container start. Change it afterwards via the Web UI."
    Type="Variable"
    Display="always"
    Required="true"
    Mask="true"></Config>

  <Config
    Name="Timezone"
    Target="TZ"
    Default="Europe/Berlin"
    Mode=""
    Description="Container timezone. See https://en.wikipedia.org/wiki/List_of_tz_database_time_zones for valid values."
    Type="Variable"
    Display="always"
    Required="false"
    Mask="false">Europe/Berlin</Config>

  <!-- ════════════════════════════════════════
       PATHS / VOLUMES
       ════════════════════════════════════════ -->
  <Config
    Name="App Data"
    Target="/omd/sites"
    Default="/mnt/user/appdata/checkmk-server"
    Mode="rw"
    Description="Persistent storage for Checkmk site data, configuration and RRD databases. Make sure this directory is empty on first start."
    Type="Path"
    Display="advanced"
    Required="true"
    Mask="false">/mnt/user/appdata/checkmk-server</Config>

  <TailscaleStateDir/>
</Container>
